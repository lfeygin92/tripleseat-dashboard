# TripleSeat OAuth 2.0 credentials
# Found in TripleSeat → Settings → API/Webhooks
TRIPLESEAT_CLIENT_ID=your_client_id_here
TRIPLESEAT_CLIENT_SECRET=your_client_secret_here

# Server config
PORT=3000

# Optional: monthly budget targets (comma-separated Jan–Dec values in dollars)
# Example: 300000,300000,800000,900000,1000000,1200000,900000,800000,1300000,1300000,600000,400000
BUDGET_TARGETS_2025=
BUDGET_TARGETS_2026=
BUDGET_TARGETS_2027=
